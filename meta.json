{
  "name": "Seedpool Auto TV/Movie IDs",
  "namespace": "github.com/cmd430",
  "match": [
    "https://seedpool.org/torrents/*/edit",
    "https://seedpool.org/torrents/create",
    "https://seedpool.org/torrents/similar/*",
    "https://seedpool.org/torrents?*"
  ],
  "grant": [
    "none"
  ],
  "inject-into": "content",
  "version": "0.2.2",
  "author": "cmd430",
  "description": "Make adding TV/Movie ids less painful during torrent moderation",
  "run-at": "document-body"
}
